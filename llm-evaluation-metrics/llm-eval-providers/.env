# DeepEval Server Configuration

# LLM Evaluation Model
# Options: gpt-4, gpt-4o, gpt-3.5-turbo, llama-3.3-70b-versatile, etc.
# Default: llama-3.3-70b-versatile
EVAL_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# API Keys (choose based on EVAL_MODEL)
# For Groq models (llama-*, mixtral-*, etc.)
GROQ_API_KEY=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

# For OpenAI models (gpt-*)
OPENAI_API_KEY=your-openai-api-key-here

# IDK Handling Configuration for Faithfulness Metric
# How to treat "idk"  in faithfulness evaluation:
# - "yes": Treat ambiguous claims as supported (lenient scoring, higher scores)
# - "no": Treat ambiguous claims as unsupported (strict scoring, lower scores)
IDK_HANDLING=yes
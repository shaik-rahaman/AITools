{
  "name": "ragas-evaluation-system",
  "version": "1.0.0",
  "description": "RAGAS Evaluation System - Frontend + Backend + Python",
  "private": true,
  "scripts": {
    "setup:workspaces": "cd frontend && npm install && cd ../backend && npm install && cd ..",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:python": "cd python && python ragas_server.py",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start": "npm run start:backend",
    "start:frontend": "cd frontend && npm run preview",
    "start:backend": "cd backend && npm start",
    "start:python": "cd python && python ragas_server.py"
  
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  }
}

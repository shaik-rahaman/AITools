{
  "name": "resume-search-rag",
  "version": "1.0.0",
  "description": "RAG-based resume search with AI chat frontend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm:backend:dev\" \"npm:frontend:dev\"",
    "backend:dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "frontend:dev": "cd recruitbot-web && npm run dev",
    "build": "npm run backend:build && npm run frontend:build",
    "backend:build": "tsc",
    "frontend:build": "cd recruitbot-web && npm run build",
    "start": "node dist/server.js",
    "test": "echo \"no test specified\" && exit 0"
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "mongodb": "^5.7.0",
    "pino": "^8.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
